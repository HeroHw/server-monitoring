# 服务器监控配置文件
# 复制此文件为 .env 并填写实际值

# 轮询间隔（秒，默认 5）
POLL_INTERVAL=5

# CPU 使用率阈值（%）
# 低于 CPU_SAFE 不记录；CPU_SAFE~CPU_WARNING 记录 INFO；
# CPU_WARNING~CPU_ALERT 记录 WARNING；超过 CPU_ALERT 记录 CRITICAL 并推送飞书
CPU_SAFE=50
CPU_WARNING=75
CPU_ALERT=90

# 内存使用率阈值（%）
MEM_SAFE=60
MEM_WARNING=80
MEM_ALERT=95

# 磁盘使用率阈值（%，监控根分区 /）
DISK_SAFE=70
DISK_WARNING=85
DISK_ALERT=95

# 飞书机器人 Webhook URL（留空则禁用飞书推送）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN_HERE

# 日志文件路径（默认 monitor.log，相对于脚本目录）
LOG_FILE=monitor.log
