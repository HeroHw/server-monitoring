# 服务器监控配置文件
# 复制此文件为 .env 并填写实际值

# 轮询间隔（秒，默认 5）
POLL_INTERVAL=5

# CPU 使用率阈值（%）
# 低于 CPU_SAFE 不记录；CPU_SAFE~CPU_WARNING 记录 INFO；
# CPU_WARNING~CPU_ALERT 记录 WARNING；超过 CPU_ALERT 记录 CRITICAL 并推送飞书
CPU_SAFE=50
CPU_WARNING=75
CPU_ALERT=90

# 内存使用率阈值（%）
MEM_SAFE=60
MEM_WARNING=80
MEM_ALERT=95

# 磁盘使用率阈值（%，监控根分区 /）
DISK_SAFE=70
DISK_WARNING=85
DISK_ALERT=95

# 飞书机器人 Webhook URL（留空则禁用飞书推送）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN_HERE

# 飞书告警消息标题中显示的服务器名称（留空则自动使用主机名）
SERVER_NAME=我的服务器

# 持续超告警阈值多少次后才推送飞书（次数 × POLL_INTERVAL = 持续秒数）
# 默认：CPU/内存连续 6 次（30s），磁盘立即（1 次）
CPU_SUSTAINED=6
MEM_SUSTAINED=6
DISK_SUSTAINED=1


LOG_FILE=monitor.log

# =============================================================================
# monitor_timewait.sh 专用配置
# =============================================================================

# 监控的目标容器名（默认 new-api-3002）
CONTAINER=new-api-3002

# TIME_WAIT 连接数告警阈值，超过此值推送飞书（默认 27000）
TIMEWAIT_THRESHOLD=27000

# 轮询间隔（秒，默认 1）
TIMEWAIT_POLL_INTERVAL=1
